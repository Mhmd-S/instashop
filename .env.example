# --- Supabase ---
# Local defaults come from `pnpm db:start` (run `pnpm exec supabase status` to confirm).
NUXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NUXT_PUBLIC_SUPABASE_KEY=sb_publishable_or_anon_jwt
NUXT_SUPABASE_SECRET_KEY=sb_secret_or_service_role_jwt

# --- Tenancy ---
NUXT_PUBLIC_APP_BASE_DOMAIN=lvh.me:3000
NUXT_PUBLIC_SITE_URL=http://lvh.me:3000

# --- Gemini (theming, M5) ---
NUXT_GEMINI_API_KEY=
NUXT_GEMINI_MODEL=gemini-2.5-flash

# --- Instagram (M4) ---
NUXT_IG_APP_ID=
NUXT_IG_APP_SECRET=
NUXT_IG_REDIRECT_URI=https://ventures-sega-operates-cheese.trycloudflare.com   /api/ig/callback
# Meta app dashboard callback URLs (register the same host as the redirect URI):
#   OAuth redirect          -> /api/ig/callback
#   Deauthorize callback    -> /api/ig/deauthorize
#   Data deletion callback  -> /api/ig/data-deletion
#   Webhooks callback       -> /api/ig/webhook   (verify token below)
NUXT_IG_WEBHOOK_VERIFY_TOKEN=
NUXT_IG_GRAPH_VERSION=v23.0

# --- Cron (token refresh) ---
# Any random string. Vercel Cron sends it as `Authorization: Bearer <value>`.
NUXT_CRON_SECRET=

# --- Stripe (M6) — Connect (Express) + destination charges ---
NUXT_STRIPE_SECRET_KEY=sk_test_...
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# From `stripe listen --forward-to http://lvh.me:3000/api/webhooks/stripe`.
# In the Stripe dashboard, also enable "Listen to events on connected accounts"
# so account.updated arrives on this same endpoint/secret.
NUXT_STRIPE_WEBHOOK_SECRET=whsec_...
# Default platform commission in basis points (150 = 1.5%); per-store override in DB.
NUXT_PLATFORM_FEE_BPS=0

# --- Email (Resend) ---
NUXT_RESEND_API_KEY=
NUXT_RESEND_FROM="Insteshop <orders@insteshop.app>"
